{
    "name": "book-reader",
    "displayName": "Book-Reader",
    "description": "VSCode 状态栏书籍阅读器，支持快捷键翻页、自动编码检测、阅读速度统计和颜色自定义",
    "keywords": [
        "book",
        "reader",
        "摸鱼",
        "小说"
    ],
    "version": "1.4.2",
    "publisher": "wangluo",
    "engines": {
        "vscode": "^1.67.0"
    },
    "categories": [
        "Other"
    ],
    "icon": "images/logo.jpg",
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/index.js",
    "contributes": {
        "configuration": {
            "title": "Book-Reader",
            "type": "object",
            "properties": {
                "bookReader.currPageNumber": {
                    "type": "number",
                    "default": 1,
                    "description": "当前页数(支持跳转)"
                },
                "bookReader.pageSize": {
                    "type": "number",
                    "default": 50,
                    "description": "每页文字数量"
                },
                "bookReader.filePath": {
                    "type": "string",
                    "default": "",
                    "description": "本地书籍路径"
                },
                "bookReader.keyWords": {
                    "type": "string",
                    "default": "",
                    "description": "跳转关键词位置"
                },
                "bookReader.showLine": {
                    "type": "boolean",
                    "default": true,
                    "description": "显示行数进度"
                },
                "bookReader.showPercent": {
                    "type": "boolean",
                    "default": true,
                    "description": "显示百分比进度"
                },
                "bookReader.showSpeed": {
                    "type": "boolean",
                    "default": true,
                    "description": "显示阅读速度"
                },
                "bookReader.textColor": {
                    "type": "string",
                    "default": "",
                    "description": "状态栏文字颜色（hex格式，如#ff6b6b，留空跟随主题）"
                },
                "bookReader.useProminentColor": {
                    "type": "boolean",
                    "default": false,
                    "description": "使用主题强调色，让阅读器在状态栏更醒目"
                }
            }
        },
        "keybindings": [
            {
                "command": "extension.prePage",
                "key": "[",
                "mac": "[",
                "when": "editorTextFocus"
            },
            {
                "command": "extension.nextPage",
                "key": "]",
                "mac": "]",
                "when": "editorTextFocus"
            },
            {
                "command": "extension.bossCode",
                "key": "ctrl+m",
                "mac": "cmd+m"
            }
        ]
    },
    "scripts": {
        "watch": "tsup --watch",
        "dev": "tsup src/index.ts --format cjs --external vscode",
        "build": "tsup src/index.ts --format cjs --external vscode && node obfuscate.js",
        "pack": "npm run build && vsce package"
    },
    "devDependencies": {
        "@types/node": "14.x",
        "@types/vscode": "^1.67.0",
        "javascript-obfuscator": "^4.1.1",
        "tsup": "^8.0.2",
        "typescript": "^4.6.4"
    },
    "license": "SEE LICENSE IN LICENSE.txt",
    "repository": {
        "type": "git",
        "url": "https://github.com/TianCai250/Book-Reader-VSCode"
    },
    "dependencies": {
        "chardet": "^2.0.0",
        "iconv-lite": "^0.6.3"
    }
}
